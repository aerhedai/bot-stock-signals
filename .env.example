# =============================================================================
# TELEGRAM BOT CONFIGURATION
# =============================================================================

# Bot token from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Telegram Group Chat ID for alerts
# To get this ID:
# 1. Add the bot to your group
# 2. Send a message in the group
# 3. Visit: https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
# 4. Look for "chat":{"id": -123456789...}
GROUP_CHAT_ID=your_group_chat_id_here

# Admin user IDs (comma-separated)
ADMIN_IDS=123456789,987654321

# Default Topic/Thread ID (used by /testalert command)
DEFAULT_MESSAGE_THREAD_ID=3

# =============================================================================
# ENGINE-SPECIFIC TELEGRAM CONFIGURATION
# Used by stock_sniper and crypto_sniper engines to send alerts directly.
# Can be the same as BOT_TOKEN/GROUP_CHAT_ID or a separate bot.
# =============================================================================

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_group_chat_id_here
# TELEGRAM_THREAD_ID=  # Optional: topic ID for engine alerts

# =============================================================================
# NEWS MONITOR CONFIGURATION
# =============================================================================

# Finnhub API Key — get a free key from https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# Topic IDs for News (separate Telegram topics for stocks and crypto)
STOCK_NEWS_TOPIC_ID=111
CRYPTO_NEWS_TOPIC_ID=112

# News fetch interval in seconds (default: 300 = 5 minutes)
NEWS_FETCH_INTERVAL=300

# =============================================================================
# GENERAL
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Database URL (optional)
DATABASE_URL=sqlite:///bot.db
